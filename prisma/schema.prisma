generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)

  address    String?
  city       String?
  zipCode    String?
  email      String?
  phone      String?
  landTitle  String?
  srmContact String?
  rib        String?
  logoUrl    String?
  logoSize   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userOrganizations UserOrganization[]
  owners            Owner[]
  buildings         Building[]
  units             Unit[]
  ownerships        Ownership[]
  monthlyDues       MonthlyDue[]
  payments          Payment[]
  receipts          Receipt[]
  otherReceipts     OtherReceipt[]
  settings          AppSettings[]
  fiscalYears       FiscalYear[]
  internalBanks     InternalBank[]
  suppliers         Supplier[]
  supplierSectors   SupplierSector[]
  accountingPosts   AccountingPost[]
  budgets           Budget[]
  importJobs        ImportJob[]
  contributionGroups ContributionGroup[]
  contributionPeriods ContributionPeriod[]
  claims            Claim[]
  claimComments     ClaimComment[]
  incidents         Incident[]
  meetings          Meeting[]
  digitalVaultDocuments DigitalVaultDocument[]
  notifications     Notification[]
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  VIEWER
  OPERATOR
  OWNER
}

enum UnitType {
  APARTMENT
  GARAGE
  COMMERCIAL
}

enum DueStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  TRANSFER
  CHECK
  DEBIT
}

model Owner {
  id        String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cin       String?
  firstName String?
  name      String
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])

  receipts   Receipt[]
  ownerships Ownership[]
  claims     Claim[]

  @@unique([organizationId, cin])
  @@index([organizationId])
  @@index([userId])
}

enum ReceiptType {
  CONTRIBUTION
  RENT
  OTHER
}

model Building {
  id        String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  createdAt DateTime @default(now())

  units    Unit[]
  receipts Receipt[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

enum ContributionType {
  GLOBAL_FIXED
  GROUP_FIXED
  SURFACE
}

model Unit {
  id        String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lotNumber String?
  reference String
  type      UnitType
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  buildingId String?
  building   Building? @relation(fields: [buildingId], references: [id])

  floor   Int?
  surface Decimal? @db.Decimal(10,2)

  overrideStart Boolean @default(false)
  startYear     Int?
  startMonth    Int?

  dues             MonthlyDue[]

  parentUnitId String?
  parentUnit   Unit?   @relation("UnitParent", fields: [parentUnitId], references: [id])
  children     Unit[]  @relation("UnitParent")

  ownerships Ownership[]
  receipts   Receipt[]
  groupUnits  ContributionGroupUnit[]
  contributionPeriods ContributionPeriod[]
  claims              Claim[]

  @@unique([organizationId, lotNumber])
  @@index([buildingId])
  @@index([organizationId])
  @@index([parentUnitId])
  @@index([lotNumber])
}

model ContributionGroup {
  id        String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  units    ContributionGroupUnit[]
  periods  ContributionPeriod[]

  @@index([organizationId])
}

model ContributionGroupUnit {
  id      String @id @default(cuid())
  groupId String
  group   ContributionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  unitId  String
  unit    Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([groupId, unitId])
  @@index([groupId])
  @@index([unitId])
}

model ContributionPeriod {
  id     String @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  contributionType ContributionType

  groupId String?
  group   ContributionGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  unitId String?
  unit   Unit?   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  startPeriod DateTime
  endPeriod   DateTime?

  amount Decimal @db.Decimal(10,2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([contributionType])
  @@index([groupId])
  @@index([unitId])
  @@index([startPeriod])
}

model Ownership {
  id        String    @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerId   String
  unitId    String
  startDate DateTime  @default(now())
  endDate   DateTime?

  owner Owner @relation(fields: [ownerId], references: [id])
  unit  Unit  @relation(fields: [unitId], references: [id])

  @@index([organizationId])
  @@index([ownerId])
  @@index([unitId])
}

model MonthlyDue {
  id     String @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id])

  period     DateTime
  amountDue  Decimal @db.Decimal(10,2)
  paidAmount Decimal @db.Decimal(10,2)       @default(0)
  status     DueStatus @default(UNPAID)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receiptAllocations ReceiptAllocation[]

  @@unique([organizationId, unitId, period])
  @@index([organizationId])
  @@index([unitId, organizationId, period])
  @@index([period])
  @@index([status])
}

model Payment {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  paymentNumber Int @default(autoincrement())

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  accountingPostId String?
  accountingPost   AccountingPost? @relation(fields: [accountingPostId], references: [id])

  date   DateTime      @default(now())
  method PaymentMethod
  amount Decimal @db.Decimal(10,2)
  note   String?
  attachments Json @default("[]")

  bankName String?
  bankRef  String?

  createdAt DateTime @default(now())

  @@unique([organizationId, paymentNumber])
  @@index([organizationId])
  @@index([supplierId])
  @@index([accountingPostId])
  @@index([date])
  @@index([paymentNumber])
}

model Receipt {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  receiptNumber Int
  type          ReceiptType @default(CONTRIBUTION)

  buildingId String
  building   Building @relation(fields: [buildingId], references: [id])

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id])

  unitId String?
  unit   Unit?   @relation(fields: [unitId], references: [id])

  date DateTime @default(now())

  method PaymentMethod
  amount Decimal @db.Decimal(10,2)
  note   String?

  bankName String?
  bankRef  String?

  unallocatedAmount Int @default(0)

  allocations ReceiptAllocation[]

  createdAt DateTime @default(now())

  @@unique([organizationId, receiptNumber])
  @@index([organizationId])
  @@index([buildingId])
  @@index([ownerId])
  @@index([unitId])
  @@index([unitId, type, date])
  @@index([date])
  @@index([receiptNumber])
  @@index([type, date, receiptNumber])
  @@index([buildingId, type, date])
  @@index([ownerId, type, date])
  @@index([method, type, date])
}

model ReceiptAllocation {
  id String @id @default(uuid())

  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id])

  dueId String
  due   MonthlyDue @relation(fields: [dueId], references: [id])

  amount Decimal @db.Decimal(10,2)

  @@index([receiptId])
  @@index([dueId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  passwordHash String?
  role         UserRole @default(OPERATOR)
  isActive     Boolean  @default(true)

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizations UserOrganization[]
  owner         Owner?
  notifications Notification[]
  claimComments ClaimComment[]
}

model UserOrganization {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role      UserRole @default(OPERATOR)
  createdAt DateTime @default(now())

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AppSettings {
  id         String @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brandName  String @default("Syndic")
  brandColor String @default("#4f46e5")

  startYear  Int @default(2026)
  startMonth Int @default(1)

  receiptStartNumber Int     @default(1)
  receiptUsePrefix   Boolean @default(false)
  receiptPrefix      String?

  paymentStartNumber Int     @default(1)
  paymentUsePrefix   Boolean @default(false)
  paymentPrefix      String?

  openingCashBalance Decimal @default(0) @db.Decimal(12,2)
  openingBankBalance Decimal @default(0) @db.Decimal(12,2)

  contributionType    ContributionType @default(GLOBAL_FIXED)
  globalFixedAmount  Decimal? @db.Decimal(10,2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId])
  @@index([organizationId])
}

model FiscalYear {
  id String @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  year Int

  startsAt DateTime
  endsAt   DateTime

  createdAt DateTime @default(now())

  @@unique([organizationId, year])
  @@index([organizationId])
  @@index([year])
}

model InternalBank {
  id        String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model Supplier {
  id       String  @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name     String
  sector   String?
  contactName String?
  phone    String?
  email    String?
  address  String?
  note     String?
  photoUrl String?
  isActive Boolean @default(true)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model SupplierSector {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

enum PostType {
  CHARGE
  PRODUCT
}

model AccountingPost {
  id       String  @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code     String
  name     String
  postType PostType
  note     String?
  isActive Boolean @default(false)

  payments Payment[]
  budgets  Budget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([postType])
}

model Budget {
  id       String  @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accountingPostId String
  accountingPost   AccountingPost @relation(fields: [accountingPostId], references: [id])
  year     Int
  amount   Decimal @db.Decimal(10,2)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, accountingPostId, year])
  @@index([organizationId])
  @@index([accountingPostId])
  @@index([year])
}

model OtherReceipt {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  receiptNumber Int

  type ReceiptType

  description String

  date DateTime @default(now())

  method PaymentMethod

  amount Decimal @db.Decimal(10,2)

  bankName String?
  bankRef  String?

  note String?

  createdAt DateTime @default(now())

  @@unique([organizationId, receiptNumber])
  @@index([organizationId])
  @@index([date])
  @@index([receiptNumber])
}

model ImportJob {
  id        String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type      String
  totalRows Int
  processed Int      @default(0)
  status    String   @default("running") // running | done | error
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model DigitalVaultDocument {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name       String
  category   String
  fileName   String
  fileUrl    String @db.Text
  mimeType   String
  sizeBytes  Int
  tags       String[] @default([])
  isVisibleToOwners Boolean @default(false)
  documentDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([category])
  @@index([isVisibleToOwners])
  @@index([documentDate])
}

model Claim {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerId        String
  owner          Owner        @relation(fields: [ownerId], references: [id])
  unitId         String?
  unit           Unit?        @relation(fields: [unitId], references: [id])
  
  title          String
  description    String
  category       String       @default("Général")
  status         ClaimStatus  @default(OPEN)
  priority       ClaimPriority @default(NORMAL)
  photos         String[]     @default([])
  notifications  Notification[]
  comments       ClaimComment[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([ownerId])
  @@index([unitId])
}

model ClaimComment {
  id             String       @id @default(uuid())
  claimId         String
  claim           Claim        @relation(fields: [claimId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  message         String       @db.Text
  createdAt       DateTime     @default(now())

  @@index([claimId, createdAt])
  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
}

model Notification {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  claimId        String?
  claim          Claim?       @relation(fields: [claimId], references: [id], onDelete: SetNull)

  type           String
  title          String
  message        String?      @db.Text
  link           String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  readAt         DateTime?

  @@index([userId, organizationId, isRead, createdAt])
  @@index([organizationId, createdAt])
  @@index([claimId])
}

enum ClaimStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ClaimPriority {
  LOW
  NORMAL
  HIGH
}

model Incident {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  description    String
  location       String?      // Apartment or Common Area
  status         String       @default("OPEN")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

model Meeting {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  date           DateTime
  type           MeetingType   @default(ORDINARY)
  status         MeetingStatus @default(SCHEDULED)
  description    String?
  location       String?
  convocationSentAt DateTime?
  minutesGeneratedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  resolutions    MeetingResolution[]
  documents      MeetingDocument[]

  @@index([organizationId])
}

enum MeetingType {
  ORDINARY
  EXTRAORDINARY
}

enum MeetingStatus {
  SCHEDULED
  CONVOCATIONS_SENT
  MINUTES_READY
  COMPLETED
}

enum MeetingVoteRule {
  SIMPLE
  ABSOLUTE
  DOUBLE
  UNANIMOUS
}

enum MeetingResolutionStatus {
  PENDING
  ADOPTED
  REJECTED
}

enum MeetingDocumentType {
  ATTENDANCE_SHEET
  MINUTES
  OTHER
}

enum MeetingDocumentSourceType {
  UPLOAD
  VAULT
}

model MeetingResolution {
  id          String                  @id @default(uuid())
  meetingId   String
  meeting     Meeting                 @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  title       String
  description String?
  voteRule    MeetingVoteRule
  status      MeetingResolutionStatus @default(PENDING)
  votesFor    Int                     @default(0)
  votesAgainst Int                    @default(0)
  abstentions Int                     @default(0)
  orderIndex  Int                     @default(0)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([meetingId, orderIndex])
}

model MeetingDocument {
  id             String                    @id @default(uuid())
  meetingId      String
  meeting        Meeting                   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  type           MeetingDocumentType
  sourceType     MeetingDocumentSourceType @default(UPLOAD)
  title          String
  fileName       String?
  fileUrl        String?                   @db.Text
  mimeType       String?
  sizeBytes      Int                       @default(0)
  vaultDocumentId String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@index([meetingId, type])
  @@index([vaultDocumentId])
}

model PageVisibilitySetting {
  id         String   @id @default(cuid())
  href       String   @unique
  title      String
  section    String
  icon       String
  isEnabled  Boolean  @default(true)
  superAdmin Boolean  @default(true)
  admin      Boolean  @default(true)
  manager    Boolean  @default(true)
  operator   Boolean  @default(true)
  viewer     Boolean  @default(true)
  owner      Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([section])
  @@index([isEnabled])
}
model SystemSettings {
  id            String   @id @default(cuid())
  prismaLogging Boolean  @default(true)
  updatedAt     DateTime @updatedAt
}
