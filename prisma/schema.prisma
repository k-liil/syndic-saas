generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
}

enum UnitType {
  APARTMENT
  GARAGE
  COMMERCIAL
}

enum DueStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  TRANSFER
  CHECK
}

model Owner {
  id        String   @id @default(uuid())
  cin       String?  @unique
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())

  receipts   Receipt[]
  ownerships Ownership[]
}

enum ReceiptType {
  CONTRIBUTION
  RENT
  OTHER
}

model Building {
  id        String   @id @default(uuid())
  name      String
  address   String?
  createdAt DateTime @default(now())

  units    Unit[]
  receipts Receipt[]
}

model Unit {
  id        String   @id @default(uuid())
  lotNumber String?  @unique
  reference String
  type      UnitType
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  buildingId String?
  building   Building? @relation(fields: [buildingId], references: [id])

  monthlyDueAmount Int?
  dues             MonthlyDue[]

  parentUnitId String?
  parentUnit   Unit?   @relation("UnitParent", fields: [parentUnitId], references: [id])
  children     Unit[]  @relation("UnitParent")

  ownerships Ownership[]
  receipts   Receipt[]

  @@index([buildingId])
  @@index([parentUnitId])
  @@index([lotNumber])
}

model Ownership {
  id        String    @id @default(uuid())
  ownerId   String
  unitId    String
  startDate DateTime  @default(now())
  endDate   DateTime?

  owner Owner @relation(fields: [ownerId], references: [id])
  unit  Unit  @relation(fields: [unitId], references: [id])

  @@index([ownerId])
  @@index([unitId])
}

model MonthlyDue {
  id     String @id @default(uuid())
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id])

  period     DateTime
  amountDue  Int
  paidAmount Int       @default(0)
  status     DueStatus @default(UNPAID)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receiptAllocations ReceiptAllocation[]

  @@unique([unitId, period])
  @@index([period])
  @@index([status])
}

model Payment {
  id String @id @default(uuid())

  paymentNumber Int @unique @default(autoincrement())

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  categoryId String?
  category   PaymentCategory? @relation(fields: [categoryId], references: [id])

  date   DateTime      @default(now())
  method PaymentMethod
  amount Int
  note   String?

  bankName String?
  bankRef  String?

  createdAt DateTime @default(now())

  @@index([supplierId])
  @@index([categoryId])
  @@index([date])
  @@index([paymentNumber])
}

model Receipt {
  id String @id @default(uuid())

  receiptNumber Int         @unique
  type          ReceiptType @default(CONTRIBUTION)

  buildingId String
  building   Building @relation(fields: [buildingId], references: [id])

  ownerId String
  owner   Owner  @relation(fields: [ownerId], references: [id])

  unitId String?
  unit   Unit?   @relation(fields: [unitId], references: [id])

  date DateTime @default(now())

  method PaymentMethod
  amount Int
  note   String?

  bankName String?
  bankRef  String?

  unallocatedAmount Int @default(0)

  allocations ReceiptAllocation[]

  createdAt DateTime @default(now())

  @@index([buildingId])
  @@index([ownerId])
  @@index([unitId])
  @@index([date])
  @@index([receiptNumber])
  @@index([type, date, receiptNumber])
@@index([buildingId, type, date])
@@index([ownerId, type, date])
@@index([method, type, date])
}

model ReceiptAllocation {
  id String @id @default(uuid())

  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id])

  dueId String
  due   MonthlyDue @relation(fields: [dueId], references: [id])

  amount Int

  @@index([receiptId])
  @@index([dueId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  passwordHash String?
  role         UserRole @default(OPERATOR)
  isActive     Boolean  @default(true)

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AppSettings {
  id         String @id @default(uuid())
  brandName  String @default("Syndic")
  brandColor String @default("#4f46e5")

  startYear  Int @default(2026)
  startMonth Int @default(1)

  receiptStartNumber Int     @default(1)
  receiptUsePrefix   Boolean @default(false)
  receiptPrefix      String?

  paymentStartNumber Int     @default(1)
  paymentUsePrefix   Boolean @default(false)
  paymentPrefix      String?

  openingCashBalance Int @default(0)
  openingBankBalance Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FiscalYear {
  id String @id @default(uuid())

  year Int

  startsAt DateTime
  endsAt   DateTime

  createdAt DateTime @default(now())

  @@unique([year])
  @@index([year])
}

model InternalBank {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id       String  @id @default(cuid())
  name     String
  phone    String?
  email    String?
  address  String?
  note     String?
  isActive Boolean @default(true)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentCategory {
  id       String  @id @default(cuid())
  name     String
  note     String?
  isActive Boolean @default(true)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OtherReceipt {
  id String @id @default(uuid())

  receiptNumber Int @unique

  type ReceiptType

  description String

  date DateTime @default(now())

  method PaymentMethod

  amount Int

  bankName String?
  bankRef  String?

  note String?

  createdAt DateTime @default(now())

  @@index([date])
  @@index([receiptNumber])
}

model ImportJob {
  id        String   @id @default(uuid())
  type      String
  totalRows Int
  processed Int      @default(0)
  status    String   @default("running") // running | done | error
  createdAt DateTime @default(now())
}